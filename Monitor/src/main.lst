    15                                  ; defines
    16                                  ;======================================================================
    17                                  
    18                                  cseg        equ 0F000h
    19                                  dseg        equ 01000h
    20                                  sseg        equ 07000h
    21                                  
    22                                  port_led    equ 08h
    23                                  port_uart   equ 16h
    24                                  
    25                                  org         START
    26                                  
    27                                  
    28                                  ;======================================================================
    29                                  ; monitor start
    30                                  ;======================================================================
    31                                  
    32                                  start:
    33                                  ; initialise SS/SP
    34 0000004B B80070                      mov ax,sseg
    35 0000004E 8ED0                        mov ss,ax
    36 00000050 BCFFFF                      mov sp,0FFFFh
    37                                  
    38 00000053 FA                          cli
    39 00000054 FC                          cld
    40                                  
    41                                  ; initialise interrupts
    42 00000055 0E                          push cs
    43 00000056 1F                          pop ds
    44                                  
    45 00000057 31FF                        xor di,di
    46 00000059 8EC7                        mov es,di
    47 0000005B BE[000F]                    mov si,interrupts
    48 0000005E B800F0                      mov ax,cseg
    49 00000061 B92000                      mov cx,32
    50                                  .copy:
    51 00000064 A5                          movsw               ; off (copied from table)
    52 00000065 AB                          stosw               ; seg (AX)
    53 00000066 E2FC                        loop .copy
    54                                  
    55                                  ; initialise DS
    56 00000068 B80010                      mov ax,dseg
    57 0000006B 8ED8                        mov ds,ax
    58                                  
    59                                  
    60                                  ; stage 1
    61                                  .start_test:
    62 0000006D B001                        mov al,1
    63 0000006F E89BFF                      call set_leds
    64 00000072 B8D007                      mov ax,2000
    65 00000075 E888FF                      call delay_ms
    66                                  
    67 00000078 CD03                        int 3
    68                                  
    69                                  
    70                                  ; stage 2
    71 0000007A B002                        mov al,2
    72 0000007C E88EFF                      call set_leds
    73 0000007F B8D007                      mov ax,2000
    74 00000082 E87BFF                      call delay_ms
    75                                  
    76 00000085 CD03                        int 3
    77                                  
    78                                  
    79                                  ; stage 3
    80 00000087 B004                        mov al,4
    81 00000089 E881FF                      call set_leds
    82 0000008C B8D007                      mov ax,2000
    83 0000008F E86EFF                      call delay_ms
    84                                  
    85 00000092 B708                        mov bh,8
    86 00000094 B000                        mov al,0
    87 00000096 F6F7                        div bh              ; div by zero
    88                                  
    89                                  
    90                                  ; finish
    91 00000098 B000                        mov al,0
    92 0000009A E870FF                      call set_leds
    93 0000009D EBCE                        jmp .start_test
    94                                  
    95                                  
    96                                  halt:
    97 0000009F F4                          hlt
    98 000000A0 EBFD                        jmp halt
    99                                  
