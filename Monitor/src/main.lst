     6                                  cpu 8086
     7                                  
     8                                  %include "config.inc"
     1                              <1> 
     2                              <1> %define BUILD       '20240415'
     3                              <1> %define VERSION     01h
     4                              <1> 
     5                              <1> %define START       0F000h
     6                              <1> 
     9                                  %include "delay.inc"
     1                              <1> ;======================================================================
     2                              <1> ; delay by a give number of milliseconds
     3                              <1> ; Dylan Hall, April 2024
     4                              <1> ;======================================================================
     5                              <1> ; CLK timings from https://zsmith.co/intel.php
     6                              <1> ; @ 20Mhz 1ms = 20000 CLK
     7                              <1> ; 13 CLK per inner loop, 8 for final inner loop
     8                              <1> ; 12 CLK per outer loop, 7 for final outer loop
     9                              <1> ; 19 + m once
    10                              <1> ; delay = 19 + m + ((ax - 1) * 12) + 7 + (ax * 13 * (bx - 1)) + (ax * 8)
    11                              <1> ; ax=1, bx = 1538 => 19 + m + 7 + (13 * 1537) + 8 => 20015 + m
    12                              <1> ; ax=1, bx = 1537 => 19 + m + 7 + (13 * 1536) + 8 => 20002 + m
    13                              <1> ; ax=2, bx = 1538 => 19 + m + (12 * 1) + 7 + (2 * 13 * 1537) + (2 * 8) => 40016 + m
    14                              <1> ; ax=2, bx = 1537 => 19 + m + (12 * 1) + 7 + (2 * 13 * 1536) + (2 * 8) => 39990 + m
    15                              <1> ; ax=60000, bx = 1538 => 19 + m + (12 * 59999) + 7 + (60000 * 13 * 1537) + (60000 * 8) => 1200060014 + m => 60003ms
    16                              <1> ; ax=60000, bx = 1537 => 19 + m + (12 * 59999) + 7 + (60000 * 13 * 1536) + (60000 * 8) => 1199280014 + m => 59964ms
    17                              <1> ; going with bx = 1538
    18                              <1> ;======================================================================
    19                              <1> 
    20                              <1> delay_ms:
    21 00000000 53                  <1>     push bx         ; CLK = 3
    22                              <1> delay_ms1:
    23 00000001 BB0206              <1>     mov bx,1538     ; CLK = 2
    24                              <1> delay_ms2:
    25 00000004 90                  <1>     nop             ; CLK = 3
    26 00000005 4B                  <1>     dec bx          ; CLK = 2
    27 00000006 75FC                <1>     jnz delay_ms2   ; CLK = 7 + 1 OR 3
    28 00000008 48                  <1>     dec ax          ; CLK = 2
    29 00000009 75F6                <1>     jnz delay_ms1   ; CLK = 7 + 1 OR 3
    30 0000000B 5B                  <1>     pop bx          ; CLK = 5
    31 0000000C C3                  <1>     ret             ; CLK = 11 + m
    32                              <1> 
    10                                  %include "led.inc"
     1                              <1> ;======================================================================
     2                              <1> ; set LEDs to bit pattern given in AL
     3                              <1> ;
     4                              <1> ; bits: 76543210
     5                              <1> ;======================================================================
     6                              <1> 
     7                              <1> set_leds:
     8 0000000D E608                <1>     out port_led,al
     9 0000000F C3                  <1>     ret
    10                              <1> 
    11                                  %include "macro.inc"
