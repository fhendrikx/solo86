#!/usr/bin/perl -w
######################################################################
# bin2hex - convert binary to Intel Hex File.
#
# This utility handles IHX files that are over 64KB. This is done by
# simply ensuring that any writes over 65536 bytes are wrapped around
# to 0, while a second segment record is inserted for the new segment.
#
# Ferry Hendrikx, May 2024
######################################################################

use strict;
use warnings;

use Getopt::Long;


######################################################################
# functions
######################################################################

sub checksum
{
    my $data    = shift;
    my $total   = 0;

    foreach my $val (unpack("(A2)*", $data))
    {
        $val = hex $val;
        $total += $val;
    }

    return ((-1 * $total) & 0xFF);
}

sub print_line
{
    my $data    = shift;

    # :<data><checksum>

    printf(":%s%02X\n", $data, checksum($data));

    return (0);
}

sub print_data
{
    my $offs    = shift;
    my $bin     = shift;

    my $len     = length($bin);

    # byte count, address, type (00), data

    print_line(sprintf("%02X%04X00%s", $len, $offs, uc unpack("H".$len*2, $bin)));

    return (0);
}

sub print_segment
{
    my $seg     = shift;

    # byte count, address, type (02), segment

    print_line(sprintf("%02X%04X02%04X", 2, 0, $seg));

    return (0);
}

sub print_start
{
    my $cs      = shift;
    my $ip      = shift;

    # byte count, address, type (03), CS, IP

    print_line(sprintf("%02X%04X03%04s%04s", 4, 0, $cs, $ip));

    return (0);
}

sub print_eof
{
    # byte count, address, type (01)

    print_line(sprintf("%02X%04X01", 0, 0));

    return (0);
}

sub usage
{
    print "usage: bin2hex --file=<file> [ --seg=segment ] [ --start=CS:IP ]\n\n";

    print "  bin2hex --file=image.rom\n";
    print "  bin2hex --file=image.rom --seg=F000\n";
    print "  bin2hex --file=image.rom --seg=F000 --start=F000:FFF0\n";

    exit (0);
}


######################################################################
# main
######################################################################

my $file;
my $seg;
my $off = 0;
my $addr;

GetOptions(
    "file=s"        => \$file,
    "seg=s"         => \$seg,
    "start=s"       => \$addr,
);


# sanity check

if (! $file)
{
    usage();
}


# segment is in decimal

$seg    = hex $seg;


# starting address (CS:IP)

if ($addr)
{
    my ($cs,$ip) = $addr =~ /([0-9A-F]{4})\:([0-9A-F]{4})/i;

    print_start($cs, $ip);
}


# process file

open (my $fh, "<", "$file") || die "unable to open file";
binmode($fh);
while (!eof($fh))
{
    my $bin;
    my $ret = read($fh, $bin, 16);

    if ($ret)
    {
        # are we starting a new segment?

        if ($off == 0)
        {
            # let IHX loader know what we're doing

            print_segment($seg);
        }


        # print 16 bytes of data

        print_data($off, $bin);


        # are we at the end of a segment?

        if ($off >= 65520)
        {
            # wrap around to a new segment

            $seg = $seg + 4096;
            $off = 0;
        }
        else
        {
            # next 16 bytes

            $off += 16;
        }
    }
}

close ($fh);

print_eof();

