S2.ar  =>
    RESET

S2.sp  =>
    0 

STATE =>
    S2 , S1 , S0

WAIT.d  =>
    !A0 & !A4 & A5 & !A6 & !A7 & !BHE & IOWR & !S0 & !S1 & !S2
  # !A0 & !A4 & A5 & !A6 & !A7 & !BHE & IORD & !S0 & !S1 & !S2
